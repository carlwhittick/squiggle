{
  "name": "@carlwhittick/squiggle",
  "version": "1.0.0",
  "description": "Canvas-drawn animated squiggle underlines with ripple effects on hover/click",
  "type": "module",
  "main": "./dist/squiggle.umd.cjs",
  "module": "./dist/squiggle.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/squiggle.js",
      "require": "./dist/squiggle.umd.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc --noEmit && vite build",
    "prepublishOnly": "npm run build",
    "test": "npm run build && playwright test"
  },
  "keywords": [
    "squiggle",
    "underline",
    "canvas",
    "ripple",
    "animation",
    "text-decoration"
  ],
  "author": "Carl Whittick",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/carlwhittick/squiggle.git"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/pngjs": "^6.0.5",
    "pngjs": "^7.0.0",
    "typescript": "^5.0.0",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.0.0"
  }
}
